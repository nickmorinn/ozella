<div class="product-shipping-eta" data-product-shipping-eta>
  <span class="product-shipping-eta__icon" aria-hidden="true">
    <svg class="icon icon-truck" viewBox="0 0 64 64" focusable="false" role="presentation">
      <path d="M7 18h32v26H7zM39 26h10l8 8v10H39z" />
      <circle cx="20" cy="48" r="4" />
      <circle cx="48" cy="48" r="4" />
      <path d="M24 48h20M39 36h18" />
    </svg>
  </span>
  <span class="product-shipping-eta__text">
    <span>Ships within 24 hours, receive by </span>
    <span data-shipping-eta-date>...</span>
  </span>
</div>

<script>
  (function() {
    var CST_TIMEZONE = 'America/Chicago';

    var getCstParts = function(date) {
      var formatter = new Intl.DateTimeFormat('en-US', {
        timeZone: CST_TIMEZONE,
        year: 'numeric',
        month: '2-digit',
        day: '2-digit',
        hour: '2-digit',
        minute: '2-digit',
        hour12: false
      });

      var parts = formatter.formatToParts(date);
      var map = {};

      parts.forEach(function(part) {
        if (part.type !== 'literal') {
          map[part.type] = part.value;
        }
      });

      return {
        year: parseInt(map.year, 10),
        month: parseInt(map.month, 10),
        day: parseInt(map.day, 10),
        hour: parseInt(map.hour, 10),
        minute: parseInt(map.minute, 10)
      };
    };

    var formatEtaDate = function(date) {
      return new Intl.DateTimeFormat(undefined, {
        weekday: 'short',
        month: 'short',
        day: 'numeric',
        timeZone: 'UTC'
      }).format(date);
    };

    var formatBusinessEta = function() {
      var now = new Date();
      var cstNow = getCstParts(now);
      var businessDaysToAdd = cstNow.hour < 15 ? 2 : 3;
      var date = new Date(Date.UTC(cstNow.year, cstNow.month - 1, cstNow.day));
      var businessDaysAdded = 0;

      while (businessDaysAdded < businessDaysToAdd) {
        date.setUTCDate(date.getUTCDate() + 1);
        var day = date.getUTCDay();
        if (day !== 0 && day !== 6) {
          businessDaysAdded += 1;
        }
      }

      try {
        return formatEtaDate(date);
      } catch (e) {
        return date.toUTCString().slice(0, 16);
      }
    };

    var etaText = formatBusinessEta();
    var nodes = document.querySelectorAll('[data-shipping-eta-date]');

    nodes.forEach(function(node) {
      node.textContent = etaText;
    });
  })();
</script>

{%- style -%}
  .product-shipping-eta {
    align-items: center;
    background: var(--colorBodyLightDim);
    border: 1px solid var(--colorBorder);
    border-radius: var(--buttonRadius);
    color: var(--colorTextBody);
    display: flex;
    font-family: var(--typeAccentPrimary), var(--typeAccentFallback);
    font-size: 11px;
    gap: 8px;
    justify-content: center;
    letter-spacing: var(--oz-track-ui);
    line-height: 1.3;
    margin-top: var(--oz-space-1);
    margin-bottom: var(--oz-space-1);
    padding: var(--oz-space-1) var(--oz-space-2);
    text-align: center;
    text-transform: uppercase;
    width: 100%;
  }

  .product-shipping-eta__icon {
    color: var(--colorTextBody);
    display: inline-flex;
    flex: 0 0 auto;
  }

  .product-shipping-eta__icon .icon {
    height: 16px;
    width: 16px;
  }

  .product-shipping-eta__text {
    min-width: 0;
    text-align: center;
  }

  .product-shipping-eta [data-shipping-eta-date] {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @media only screen and (max-width: 768px) {
    .product-shipping-eta {
      font-size: 10px;
      gap: 6px;
      margin-top: 6px;
      margin-bottom: 6px;
      padding: 8px 10px;
    }
  }
{%- endstyle -%}
