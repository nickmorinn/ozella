{%- assign header_font = settings.type_header_font_family -%}
{%- assign base_font = settings.type_base_font_family -%}
{%- assign base_font_bold = base_font | font_modify: 'weight', '600' -%}
{%- assign base_font_italic = base_font | font_modify: 'style', 'italic' -%}
{%- assign base_font_bold_italic = base_font_bold | font_modify: 'style', 'italic' -%}

<link
  rel="preload"
  as="font"
  href="{{ 'freighttext-pro-book-regular.woff2' | asset_url }}"
  type="font/woff2"
  crossorigin
>
<link
  rel="preload"
  as="font"
  href="{{ 'ContemporaSans-BoldCondensed.woff2' | asset_url }}"
  type="font/woff2"
  crossorigin
>
<link
  rel="preload"
  as="font"
  href="{{ 'GeneralGrotesqueMono-Regular.woff2' | asset_url }}"
  type="font/woff2"
  crossorigin
>
<link
  rel="preload"
  as="font"
  href="{{ 'Noka_Semibold.otf' | asset_url }}"
  type="font/otf"
  crossorigin
>
<link
  rel="preload"
  as="font"
  href="{{ 'Prestige Elite Std Bold.woff2' | asset_url }}"
  type="font/woff2"
  crossorigin
>

{%- style -%}
  @font-face {
    font-family: "Freight Text Pro";
    src: url({{ 'freighttext-pro-book-regular.woff2' | asset_url }}) format('woff2'),
      url({{ 'freighttext-pro-book-regular.woff' | asset_url }}) format('woff');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "Contempora Sans";
    src: url({{ 'ContemporaSans-BoldCondensed.woff2' | asset_url }}) format('woff2'),
      url({{ 'ContemporaSans-BoldCondensed.woff' | asset_url }}) format('woff');
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "Noka Semibold";
    src: url({{ 'Noka_Semibold.otf' | asset_url }}) format('opentype');
    font-weight: 600;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "HURDEI";
    src: url({{ 'HURDEI.ttf' | asset_url }}) format('truetype');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "Actay";
    src: url({{ 'Actay-Regular.otf' | asset_url }}) format('opentype');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "Antique Olive Std";
    src: url({{ 'Antique-Olive-Std-Light_3866.ttf' | asset_url }}) format('truetype');
    font-weight: 300;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "Antique Olive Std";
    src: url({{ 'Antique-Olive-Std-Roman_3869.ttf' | asset_url }}) format('truetype');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "Antique Olive Std";
    src: url({{ 'Antique-Olive-Std-Italic_3865.ttf' | asset_url }}) format('truetype');
    font-weight: 400;
    font-style: italic;
    font-display: swap;
  }

  @font-face {
    font-family: "Antique Olive Std";
    src: url({{ 'Antique-Olive-Std-Bold_3863.ttf' | asset_url }}) format('truetype');
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "Antique Olive Std";
    src: url({{ 'Antique-Olive-Std-Black_3861.ttf' | asset_url }}) format('truetype');
    font-weight: 900;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "Antique Olive Std Nord";
    src: url({{ 'Antique-Olive-Std-Nord_3868.ttf' | asset_url }}) format('truetype');
    font-weight: 900;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "Antique Olive Std Nord";
    src: url({{ 'Antique-Olive-Std-Nord-Italic_3867.ttf' | asset_url }}) format('truetype');
    font-weight: 900;
    font-style: italic;
    font-display: swap;
  }

  @font-face {
    font-family: "Antique Olive Std Bold Condensed";
    src: url({{ 'Antique-Olive-Std-Bold-Condensed_3862.ttf' | asset_url }}) format('truetype');
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "Antique Olive Std Compact";
    src: url({{ 'Antique-Olive-Std-Compact_3864.ttf' | asset_url }}) format('truetype');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "Prestige Elite Std";
    src: url({{ 'Prestige Elite Std Bold.woff2' | asset_url }}) format('woff2'),
      url({{ 'Prestige Elite Std Bold.woff' | asset_url }}) format('woff');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
    /* Normalize vertical metrics for better baseline alignment across browsers */
    ascent-override: 84%;
    descent-override: 16%;
    line-gap-override: 0%;
  }

  @font-face {
    font-family: "GeneralGrotesqueMono-Regular";
    src: url({{ 'GeneralGrotesqueMono-Regular.woff2' | asset_url }}) format('woff2'),
      url({{ 'GeneralGrotesqueMono-Regular.woff' | asset_url }}) format('woff');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "Prestige Elite Std";
    src: url({{ 'Prestige Elite Std Bold.woff2' | asset_url }}) format('woff2'),
      url({{ 'Prestige Elite Std Bold.woff' | asset_url }}) format('woff');
    font-weight: 700;
    font-style: normal;
    font-display: swap;
    /* Normalize vertical metrics for better baseline alignment across browsers */
    ascent-override: 84%;
    descent-override: 16%;
    line-gap-override: 0%;
  }

  {{ header_font | font_face: font_display: 'swap' }}
  {{ base_font | font_face: font_display: 'swap' }}

  {{ base_font_bold | font_face: font_display: 'swap' }}
  {{ base_font_italic | font_face: font_display: 'swap' }}
  {{ base_font_bold_italic | font_face: font_display: 'swap' }}
{%- endstyle -%}
